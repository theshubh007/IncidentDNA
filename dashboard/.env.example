# ═══════════════════════════════════════════════════════════════
# ReleaseShield — Environment Configuration
# Copy this file to .env.local for local development
# ═══════════════════════════════════════════════════════════════

# ── Backend API ───────────────────────────────────────────────
# Base URL for the ReleaseShield FastAPI backend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket URL for real-time event streaming
VITE_WS_URL=ws://localhost:8000/ws

# ── Snowflake (Data Warehouse) ────────────────────────────────
VITE_SNOWFLAKE_ACCOUNT=
VITE_SNOWFLAKE_WAREHOUSE=COMPUTE_WH
VITE_SNOWFLAKE_DATABASE=INCIDENTDNA
VITE_SNOWFLAKE_SCHEMA=PUBLIC

# ── CrewAI Agent Endpoint ─────────────────────────────────────
VITE_CREWAI_ENDPOINT=http://localhost:8001/run
VITE_CREWAI_API_KEY=

# ── Composio (Slack + GitHub Tool Calls) ──────────────────────
VITE_COMPOSIO_API_KEY=
VITE_COMPOSIO_SLACK_CONNECTION_ID=
VITE_COMPOSIO_GITHUB_CONNECTION_ID=

# ── Feature Flags ─────────────────────────────────────────────
# Set to "true" to use live API data, "false" for mock data
VITE_USE_LIVE_DATA=false

# Enable WebSocket real-time streaming
VITE_ENABLE_REALTIME=false

# Enable simulation mode (shows Simulate Event button)
VITE_ENABLE_SIMULATION=true

# ── App Settings ──────────────────────────────────────────────
VITE_APP_NAME=ReleaseShield
VITE_APP_VERSION=1.0.0-beta
VITE_DEFAULT_ENVIRONMENT=prod
